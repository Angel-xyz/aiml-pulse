<!DOCTYPE html>
<html lang="en">
<head>
<!-- AI Made Template-->
  <meta charset="utf-8">
  <title>AI/ML Pulse — Weekly Digest — {{ today.isoformat() }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --bg: #0d1117; --fg: #e6edf3; --muted: #8b949e; --accent: #58a6ff;
      --border: #30363d; --panel: #161b22;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
           background: var(--bg); color: var(--fg); line-height: 1.5; }
    .wrap { max-width: 960px; margin: 0 auto; padding: 32px 24px 64px; }
    header { display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 24px; }
    header h1 { margin: 0; font-size: 1.6rem; letter-spacing: -0.01em; }
    header .meta { color: var(--muted); font-size: 0.9rem; }
    h2 { font-size: 1.15rem; border-bottom: 1px solid var(--border); padding-bottom: 6px; margin-top: 36px; }
    .grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
    @media (min-width: 800px) { .grid-2 { grid-template-columns: 1fr 1fr; } }
    .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 8px; padding: 16px 18px; }
    .panel h3 { margin: 0 0 8px; font-size: 1rem; color: var(--accent); }
    ul { padding-left: 18px; margin: 0; }
    li { margin-bottom: 8px; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .source { color: var(--muted); font-size: 0.85rem; }
    .delta-up { color: #3fb950; }
    .delta-down { color: #f85149; }
    .delta-flat { color: var(--muted); }
    code { background: var(--panel); padding: 1px 6px; border-radius: 4px; font-size: 0.9em; }
    footer { color: var(--muted); font-size: 0.85rem; margin-top: 48px; text-align: center; }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <h1>AI/ML Pulse</h1>
      <div class="meta">Week of {{ today.isoformat() }} · last {{ days }} days</div>
    </header>

    <div class="grid grid-2">
      <section class="panel">
        <h3>Trending topics</h3>
        {% if trending %}
        <ul>
          {% for t in trending %}
          <li>
            <code>{{ t.label }}</code> · {{ t.this_week }} this week
            {% if t.delta > 0 %}<span class="delta-up">▲ +{{ t.delta }}</span>
            {% elif t.delta < 0 %}<span class="delta-down">▼ {{ t.delta }}</span>
            {% else %}<span class="delta-flat">· no change</span>{% endif %}
          </li>
          {% endfor %}
        </ul>
        {% else %}
        <p class="source">No trend history yet — run <code>pulse topics</code> a few times to populate snapshots.</p>
        {% endif %}
      </section>

      <section class="panel">
        <h3>Auto-extracted topics</h3>
        {% if topics %}
        <ul>
          {% for topic in topics %}
          <li><code>{{ topic.label }}</code> · {{ topic.item_count }} items</li>
          {% endfor %}
        </ul>
        {% else %}
        <p class="source">No topics yet — run <code>pulse topics</code>.</p>
        {% endif %}
      </section>
    </div>

    <h2>Top items this week</h2>
    {% if items %}
    <ul>
      {% for item in items %}
      <li>
        <a href="{{ item.url }}">{{ item.title }}</a>
        <div class="source">
          {{ item.source.value }}{% if item.author %} · {{ item.author }}{% endif %}
          · {{ item.published_at.strftime("%Y-%m-%d") }}
          · score {{ item.score | fmt_score }}
        </div>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="source">No items in window. Try <code>pulse fetch --since 30d</code>.</p>
    {% endif %}

    <h2>By source</h2>
    {% for source, source_items in items_by_source.items() %}
    <section class="panel" style="margin-bottom: 14px;">
      <h3>{{ source }} <span class="source">({{ source_items | length }})</span></h3>
      <ul>
        {% for item in source_items[:5] %}
        <li><a href="{{ item.url }}">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </section>
    {% endfor %}

    <footer>Generated by <code>pulse digest</code> · aiml-pulse v0.1.0</footer>
  </div>
</body>
</html>
